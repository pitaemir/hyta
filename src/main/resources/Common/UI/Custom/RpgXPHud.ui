Group #Root {
  Anchor: (Left: 22, Bottom: 24, Width: 340, Height: 62);

  Group #PanelShadow {
    Anchor: (Left: 2, Top: 2, Width: 316, Height: 50);
    Background: #000000;
  }

  Group #Panel {
    Anchor: (Left: 0, Top: 0, Width: 316, Height: 50);
    Background: #141a22;
  }

  Label #LevelLabel {
    Style: (TextColor: #f4d35e, FontSize: 18, RenderBold: true);
    Anchor: (Left: 12, Top: 7, Width: 64, Height: 18);
    Text: "LV 1";
  }

  Label #XpText {
    Style: (TextColor: #d8dee9, FontSize: 14);
    Anchor: (Left: 78, Top: 9, Width: 220, Height: 16);
    Text: "0 / 240 XP";
  }

  Group #BarOuter {
    Anchor: (Left: 12, Top: 29, Width: 292, Height: 12);
    Background: #0b0f14;
  }

  Group #BarInner {
    Anchor: (Left: 1, Top: 1, Width: 290, Height: 10);
    Background: #1d2430;
  }

  Group #XpBarFill {
    Anchor: (Left: 1, Top: 1, Width: 0, Height: 10);
    Background: #34d26a;
  }

  Group #XpBarHighlight {
    Anchor: (Left: 1, Top: 1, Width: 0, Height: 3);
    Background: #8df7b0;
  }
}